# Database Configuration
# This should point to your PostgreSQL instance. When running via docker-compose, the hostname is 'db'
DB_URL=postgres://user:pass@db:5432/apikeys

# Redis Configuration
# This should point to your Redis instance. When running via docker-compose, the hostname is 'redis'
REDIS_URL=redis://redis:6379

# Server Port (Optional)
PORT=3000
